@{
  // 1. Tell ASP.NET this layout sits inside the main Top Nav layout
  Layout = "_Layout";

  // 2. Helper function to highlight the active link based on the current URL
  var currentPage = Convert.ToString(ViewContext.RouteData.Values["page"]) ?? string.Empty;
  string IsActive(string targetPage) => currentPage.Equals(targetPage, StringComparison.OrdinalIgnoreCase) ? "active" :
string.Empty;

  // 3. Safely grab the data passed from the backend (.cshtml.cs)
  var sidebarTitle = ViewData["SidebarTitle"] as string ?? "Menu";
  var sidebarLinks = ViewData["SidebarLinks"] as List<(string Name, string Url, string Icon)> ?? new List<(string, string,
string)>();
}

@section Styles {
  <style>
    /* MAIN WRAPPER */
    .layout-wrapper {
      display: flex;
      min-height: calc(100vh - 72px);
      padding-left: 250px;
    }

    /* DYNAMIC SIDEBAR */
    .sidebar {
      width: 250px;
      background-color: #ffffff;
      border-right: 1px solid #e5e7eb;
      padding: 20px 0;

      position: fixed;
      top: 72px;
      left: 0;
      bottom: 0;
      z-index: 90;
      margin: 15px;

      /* Flex layout */
      display: flex;
      flex-direction: column;
      flex-shrink: 0;

      /* Scroll settings */
      overflow-y: auto;
      max-height: calc(100vh - 72px);

      /* Curved borders (Right side only) */
      border-top-right-radius: 20px;
      border-bottom-right-radius: 20px;
    }

    /* CUSTOM WEBKIT SCROLLBAR */
    .sidebar::-webkit-scrollbar {
      width: 6px;
    }

    .sidebar::-webkit-scrollbar-track {
      background: transparent;
    }

    .sidebar::-webkit-scrollbar-thumb {
      background-color: #cbd5e1;
      border-radius: 10px;
    }

    .sidebar::-webkit-scrollbar-thumb:hover {
      background-color: #94a3b8;
    }

    /* SIDEBAR NAVIGATION LINKS */
    .sidebar-nav {
      display: flex;
      flex-direction: column;
      gap: 5px;
      padding: 0 15px;
    }

    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 15px;
      color: #4b5563;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 500;
      transition: all 0.2s;
    }

    .sidebar-nav a:hover {
      background-color: #f3f4f6;
      color: #111827;
    }

    .sidebar-nav a.active {
      background-color: #eff6ff;
      color: #2563eb;
    }

    .sidebar-nav .material-symbols-outlined {
      font-size: 20px;
    }

    /* CONTENT AREA */
    .content-area {
      flex-grow: 1;
      width: 100%;
      /* Ensures the content fully stretches out */
      padding: 24px;
      background-color: #f5f7fb;
      /* Matches your site.css var(--bg) */
      overflow-y: auto;
    }
  </style>

  @await RenderSectionAsync("Styles", required: false)
}

<div class="layout-wrapper">
  <aside class="sidebar">

    <div class="px-4 mb-3">
      <span class="text-uppercase fw-bold text-secondary" style="font-size: 0.75rem; letter-spacing: 0.05em;">
        @sidebarTitle
      </span>
    </div>

    <nav class="sidebar-nav">
      @foreach (var link in sidebarLinks)
      {
        <a asp-page="@link.Url" class="@IsActive(link.Url)">
          <span class="material-symbols-outlined">@link.Icon</span> @link.Name
        </a>
      }
    </nav>

  </aside>

  <div class="content-area">
    @RenderBody()
  </div>
</div>

@section Scripts {
  @await RenderSectionAsync("Scripts", required: false)
}
