<!DOCTYPE html>
@{
  var currentPage = Convert.ToString(ViewContext.RouteData.Values["page"]) ?? string.Empty;
  string IsActive(string pagePrefix) => currentPage.StartsWith(pagePrefix, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
}

<html lang="en" class="light">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>@ViewData["Title"] - kaam</title>

  <!-- Bootstrap -->
  <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Material Symbols -->
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">

  <!-- Custom CSS -->
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  @await RenderSectionAsync("Styles", required: false)


  <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/sub-dashboard.css" asp-append-version="true" />
</head>

<body class="app-body">

  <!-- TOP NAVBAR -->
  <header class="topbar">

    <div class="topbar-left">
      <a asp-page="/Index" class="brand">
        kaam
      </a>

      <nav class="top-nav">
        <a asp-page="/Index" class='@IsActive("/Index")'>Dashboard</a>

        <a asp-page="/CRM/Index" class="@IsActive("/CRM")">
          CRM
        </a>

        <a asp-page="/Production/Index" class='@IsActive("/Production")'>
          Production
        </a>

        <a asp-page="/Warehouse/Index" class='@IsActive("/Warehouse")'>
          Warehouse
        </a>

        <a asp-page="/Analytics/Index" class='@IsActive("/Analytics")'>
          Analytics
        </a>
        <a asp-page="/Privacy" class='@IsActive("/Privacy")'>Privacy</a>
      </nav>
    </div>

    <!-- RIGHT SIDE -->
    <div class="topbar-right">

      @* <div class="search-box">
        <span class="material-symbols-outlined">
          search
        </span>

        <input type="text" placeholder="Search..." />
      </div> *@

      <button class="icon-btn">
        <span class="material-symbols-outlined">
          notifications
        </span>
      </button>

      <a asp-page="/Account/Profile" class="profile-btn">

        <span class="material-symbols-outlined">
          account_circle
        </span>
      </a>
    </div>
  </header>

  <!-- PAGE CONTENT -->
  <main class="page-container">
    @RenderBody()
  </main>

  <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
  <script src="~/js/nepali-datepicker-init.js" asp-append-version="true"></script>

  @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
