@page
@model CRMModel
@{
  ViewData["Title"] = "Customer Management";
  Layout = "_SidebarLayout";
}

<!-- Reusing your existing CSS theme -->

<div class="pp-page">

  <!-- Page Header -->
  <div class="pp-page-header">
    <div>
      <h1>Customer Management</h1>
      <p>Manage customer relationships, track basic information, and take new orders.</p>
    </div>

    <div class="pp-header-actions">
      <!-- Button to create a new customer -->
      <a asp-page="/CRM/Customer/CreateCustomer" class="btn btn-primary">
        + Add New Customer
      </a>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="pp-summary-grid">
    <div class="pp-summary-card">
      <span class="summary-label">Total Customers</span>
      <strong id="totalCustomers">0</strong>
      <small>All registered customers</small>
    </div>

    <div class="pp-summary-card">
      <span class="summary-label">Active</span>
      <strong id="activeCustomers">0</strong>
      <small>Ordered in last 30 days</small>
    </div>

    <div class="pp-summary-card">
      <span class="summary-label">Pending Orders</span>
      <strong id="pendingOrders">0</strong>
      <small>Currently unfulfilled</small>
    </div>

    <div class="pp-summary-card">
      <span class="summary-label">New This Month</span>
      <strong id="newCustomers">0</strong>
      <small>Recently onboarded</small>
    </div>
  </div>

  <!-- Filter Card -->
  <div class="pp-card">
    <div class="pp-card-header">
      <div>
        <h2>Filter Customers</h2>
        <p>Search by customer details, region, status, or registration date.</p>
      </div>

      <button type="button" class="btn btn-light" id="resetFiltersBtn">
        Reset Filters
      </button>
    </div>

    <div class="pp-filter-grid">
      <div class="form-group">
        <label for="customerTypeFilter">Customer Type</label>
        <select id="customerTypeFilter" class="form-control">
          <option value="">All Types</option>
          <option value="Retail">Retail</option>
          <option value="Wholesale">Wholesale</option>
          <option value="Distributor">Distributor</option>
        </select>
      </div>

      <div class="form-group">
        <label for="statusFilter">Status</label>
        <select id="statusFilter" class="form-control">
          <option value="">All Statuses</option>
          <option value="Active">Active</option>
          <option value="Inactive">Inactive</option>
          <option value="Blacklisted">Blacklisted</option>
        </select>
      </div>

      <div class="form-group">
        <label for="fromDateFilter">Registered From (BS)</label>
        <input type="text" id="fromDateFilter" class="form-control nepali-date" placeholder="DD-MM-YYYY" readonly />
      </div>

      <div class="form-group">
        <label for="toDateFilter">Registered To (BS)</label>
        <input type="text" id="toDateFilter" class="form-control nepali-date" placeholder="DD-MM-YYYY" readonly />
      </div>

      <div class="form-group">
        <label for="customerSearch">Customer Search</label>
        <input type="text" id="customerSearch" class="form-control" placeholder="Search name, email, or phone..." />
      </div>

      <div class="form-group">
        <label for="locationSearch">Location Search</label>
        <input type="text" id="locationSearch" class="form-control" placeholder="Search city or address..." />
      </div>
    </div>
  </div>

  <!-- Table Card -->
  <div class="pp-card">
    <div class="pp-card-header">
      <div>
        <h2>Customer Directory</h2>
        <p id="tableInfoText">Showing customer records.</p>
      </div>
    </div>

    <div class="pp-table-wrapper">
      <table class="pp-table">
        <thead>
          <tr>
            <th>Customer ID</th>
            <th>Name</th>
            <th>Contact Info</th>
            <th>Location</th>
            <th>Type</th>
            <th>Total Orders</th>
            <th>Last Order Date</th>
            <th>Status</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>

        <tbody id="customersTableBody">
          <!-- Mock Data Row Example -->
          <tr>
            <td><strong>CUS-1001</strong></td>
            <td>Ram Bahadur Thapa</td>
            <td>
              <div>9841000000</div>
              <small class="text-muted">ram@example.com</small>
            </td>
            <td>Kathmandu, Bagmati</td>
            <td><span class="badge badge-info">Retail</span></td>
            <td>12</td>
            <td>15-02-2083</td>
            <td><span class="material-ok">Active</span></td>
            <td class="text-right">
              <!-- Actions: View Profile, Edit, Take New Order -->
              <div class="btn-group">
                <a href="/CRM/Details/CUS-1001" class="btn btn-sm btn-light" title="View Profile">👁️</a>
                <a href="/CRM/Edit/CUS-1001" class="btn btn-sm btn-light" title="Edit Info">✏️</a>
                <a href="/CRM/Order/CreateOrder?customerId=CUS-1001" class="btn btn-sm btn-primary" title="Take Order">+
                  Order</a>
                </div>
              </td>
            </tr>
            <!-- Empty State (Hidden by default, used by JS) -->
            <tr id="loadingRow" style="display: none;">
              <td colspan="9" class="empty-cell">
                Loading customers...
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- Scripts -->
  <script src="~/js/crm/crm-index.js" asp-append-version="true"></script>
