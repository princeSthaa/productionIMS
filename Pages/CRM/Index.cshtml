@page
@model CRMModel
@{
  ViewData["Title"] = "Customer Management";
  Layout = "_SidebarLayout";
}

<!-- Reusing your existing CSS theme -->

<div class="pp-page">

  <!-- Page Header -->
  <div class="pp-page-header">
    <div>
      <h1>Customer Management</h1>
      <p>Manage customer relationships, track basic information, and take new orders.</p>
    </div>

    <div class="pp-header-actions">
      <!-- Button to create a new customer -->
      <a asp-page="/CRM/Customer/CreateCustomer" class="btn btn-primary">
        + Add New Customer
      </a>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="pp-summary-grid">
    <div class="pp-summary-card">
      <span class="summary-label">Total Customers</span>
      <strong id="totalCustomers">0</strong>
      <small>All registered customers</small>
    </div>

    <div class="pp-summary-card">
      <span class="summary-label">Active</span>
      <strong id="activeCustomers">0</strong>
      <small>Ordered in last 30 days</small>
    </div>

    <div class="pp-summary-card">
      <span class="summary-label">Pending Orders</span>
      <strong id="pendingOrders">0</strong>
      <small>Currently unfulfilled</small>
    </div>

    <div class="pp-summary-card">
      <span class="summary-label">New This Month</span>
      <strong id="newCustomers">0</strong>
      <small>Recently onboarded</small>
    </div>
  </div>

</div>

<!-- Scripts -->
<script src="~/js/crm/crm-index.js" asp-append-version="true"></script>