@page
@model CreateCustomer
@{
  ViewData["Title"] = "Create Customer";
}

<!-- Link your custom CSS file if you have a specific one for customers, or reuse the app's main CSS -->
<link rel="stylesheet" href="~/css/customers.css" asp-append-version="true" />

<div class="pp-page">

  <!-- Page Header -->
  <div class="pp-page-header">
    <div>
      <h1>Add New Customer</h1>
      <p>Register a new client, wholesaler, or retail contact.</p>
    </div>

    <div class="pp-header-actions">
      <a asp-page="/CRM/Index" class="btn btn-light">
        &larr; Back to List
      </a>
    </div>
  </div>

  <!-- Add Customer Form -->
  <div class="pp-card">
    <div class="pp-card-header">
      <div>
        <h2>Customer Details</h2>
        <p>Please fill out the required information below.</p>
      </div>
    </div>

    <div class="card-body" style="padding: 20px;">
      <form method="post" id="addCustomerForm">

        <!-- Use a grid layout similar to your filters for two-column design -->
        <div class="pp-filter-grid" style="grid-template-columns: repeat(2, 1fr); gap: 20px;">
          <div asp-validation-summary="ModelOnly" class="text-danger" style="grid-column: 1 / -1;"></div>

          <!-- Basic Information -->
          <div class="form-group">
            <label asp-for="Input.CustomerName">Full Name <span class="text-danger">*</span></label>
            <input asp-for="Input.CustomerName" class="form-control" placeholder="e.g. Ram Shrestha" />
            <span asp-validation-for="Input.CustomerName" class="text-danger"></span>
          </div>

          <div class="form-group">
            <label asp-for="Input.CompanyName">Company / Business Name</label>
            <input asp-for="Input.CompanyName" class="form-control" placeholder="e.g. Everest Garments Pvt. Ltd." />
            <span asp-validation-for="Input.CompanyName" class="text-danger"></span>
          </div>

          <div class="form-group">
            <label asp-for="Input.Email">Email Address</label>
            <input asp-for="Input.Email" class="form-control" placeholder="contact@example.com" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
          </div>

          <div class="form-group">
            <label asp-for="Input.Phone">Phone Number <span class="text-danger">*</span></label>
            <input asp-for="Input.Phone" class="form-control" placeholder="e.g. 98XXXXXXXX" />
            <span asp-validation-for="Input.Phone" class="text-danger"></span>
          </div>

          <div class="form-group">
            <label asp-for="Input.PanVatNo">PAN / VAT Number</label>
            <input asp-for="Input.PanVatNo" class="form-control" placeholder="9-digit PAN/VAT" />
            <span asp-validation-for="Input.PanVatNo" class="text-danger"></span>
          </div>

          <div class="form-group">
            <label asp-for="Input.CustomerType">Customer Type</label>
            <select asp-for="Input.CustomerType" class="form-control">
              <option value="Retail">Retail</option>
              <option value="Wholesale">Wholesale</option>
              <option value="Distributor">Distributor</option>
              <option value="Export">Export</option>
            </select>
            <span asp-validation-for="Input.CustomerType" class="text-danger"></span>
          </div>

          <!-- Address spans full width -->
          <div class="form-group" style="grid-column: 1 / -1;">
            <label asp-for="Input.Address">Full Address</label>
            <textarea asp-for="Input.Address" class="form-control" rows="3" placeholder="Street, City, Province"></textarea>
            <span asp-validation-for="Input.Address" class="text-danger"></span>
          </div>

        </div>

        <!-- Form Actions -->
        <div class="form-actions" style="margin-top: 30px; display: flex; gap: 15px; justify-content: flex-end;">
          <button type="reset" class="btn btn-light">Clear</button>
          <button type="submit" class="btn btn-primary">Save Customer</button>
        </div>
      </form>
    </div>
  </div>

</div>

<!-- Scripts section for client-side validation if needed -->
@section Scripts {
  <partial name="_ValidationScriptsPartial" />
  <script src="~/js/customer-create.js" asp-append-version="true"></script>
}
