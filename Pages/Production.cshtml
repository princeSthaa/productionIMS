@page
@model Production
@{
  ViewData["Title"] = "Production IMS";
}
<h1>@ViewData["Title"]</h1>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Production Plan - Dynamic UI</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="~/css/production.css" asp-append-version="true" />

</head>

<body class="p-4">

  <div id="listView" class="container-fluid max-w-1200 mx-auto">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h1 class="fs-4 fw-bold mb-1">Production Plans</h1>
        <p class="text-secondary small mb-0">Manage and oversee manufacturing schedules.</p>
      </div>
      <a asp-page="/CreatePlan" class="btn btn-primary fw-semibold text-white text-decoration-none">
        <i class="fa-solid fa-plus me-1"></i> Create Plan
      </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light border-bottom">
            <tr>
              <th class="text-secondary text-uppercase fw-semibold py-3 ps-4" style="font-size: 0.75rem;">Plan Name</th>
              <th class="text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem;">Basis</th>
              <th class="text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem;">Target Qty</th>
              <th class="text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem;">Timeline</th>
              <th class="text-secondary text-uppercase fw-semibold" style="font-size: 0.75rem;">Status</th>
            </tr>
          </thead>
          <tbody id="plansTableBody">
            <tr id="emptyStateRow">
              <td colspan="5" class="text-center text-secondary py-5">
                <i class="fa-regular fa-folder-open fs-2 mb-2"></i>
                <p class="mb-0">No production plans created yet. Click "Create Plan" to get started.</p>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script>
      // Run this function immediately when the page loads
      document.addEventListener('DOMContentLoaded', function () {
        renderTable();
      });

      function renderTable() {
        const plansTableBody = document.getElementById('plansTableBody');
        const emptyStateRow = document.getElementById('emptyStateRow');

        // 1. Get data from LocalStorage (This is the crucial step!)
        let savedPlans = JSON.parse(localStorage.getItem('productionPlans')) || [];

        // 2. Clear existing table rows (except the empty state)
        const rows = plansTableBody.querySelectorAll('.plan-data-row');
        rows.forEach(row => row.remove());

        // 3. Handle Empty State vs Data State
        if (savedPlans.length === 0) {
          emptyStateRow.style.display = 'table-row';
        } else {
          emptyStateRow.style.display = 'none';

          // 4. Generate HTML for each plan found in LocalStorage
          savedPlans.forEach(plan => {
            const badgeClass = plan.basis === 'Customer Demand' ? 'bg-primary-subtle text-primary' : 'bg-warning-subtle text-warning-emphasis';

            const tr = document.createElement('tr');
            tr.className = 'plan-data-row';
            tr.innerHTML = `
                            <td class="ps-4 fw-semibold text-dark">${plan.name}</td>
                            <td><span class="badge ${badgeClass} rounded-pill border">${plan.basis}</span></td>
                            <td class="fw-medium">${plan.targetQty}</td>
                            <td class="text-secondary small">${plan.timeline}</td>
                            <td><span class="badge bg-secondary-subtle text-secondary border rounded-pill">Draft</span></td>
                        `;
            plansTableBody.appendChild(tr);
          });
        }
      }
  </script>
</body>
