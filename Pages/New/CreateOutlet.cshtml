@page
@model Kaam.Pages.New.CreateOutletModel
@{
    ViewData["Title"] = "Create Outlet Production Plan";
}

<link rel="stylesheet" href="~/css/plan.css" asp-append-version="true" />

<div class="pp-page">

    <div class="pp-page-header">
        <div>
            <h1>Create Outlet Replenishment Plan</h1>
            <p>Plan garment production for outlet stock replenishment.</p>
        </div>

        <div class="pp-header-actions">
            <a asp-page="/New/Create" class="btn btn-light">Change Demand Type</a>
            <a asp-page="/New/Index" class="btn btn-light">Back to Plans</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post" id="productionPlanForm">

        <input asp-for="DemandType" type="hidden" id="demandType" value="Outlet Replenishment" />
        <input asp-for="OutletId" type="hidden" id="outletId" />

        <div class="pp-create-grid">

            <section class="pp-card">
                <div class="pp-card-header">
                    <div>
                        <h2>Outlet Information</h2>
                        <p>Select the outlet that needs replenishment.</p>
                    </div>
                </div>

                <div class="form-grid two-col">
                    <div class="form-group">
                        <label asp-for="PlanNo">Plan No</label>
                        <input asp-for="PlanNo" class="form-control" readonly />
                    </div>

                    <div class="form-group">
                        <label asp-for="PlanDate">Plan Date</label>
                        <input asp-for="PlanDate" type="date" class="form-control" readonly />
                    </div>
                </div>

                <div id="outletSection" class="conditional-section">
                    <div class="section-action-row">
                        <div>
                            <h3>Outlet Replenishment</h3>
                            <p>Select an existing outlet from outlet master data.</p>
                        </div>

                        <button type="button" class="btn btn-primary" id="openOutletModalBtn">
                            Select Outlet
                        </button>
                    </div>

                    <div id="selectedOutletCard" class="selected-info-card hidden">
                        <div>
                            <span>Outlet Code</span>
                            <strong id="selectedOutletCode">-</strong>
                        </div>
                        <div>
                            <span>Outlet Name</span>
                            <strong id="selectedOutletName">-</strong>
                        </div>
                        <div>
                            <span>Location</span>
                            <strong id="selectedOutletLocation">-</strong>
                        </div>
                        <div>
                            <span>Manager</span>
                            <strong id="selectedOutletManager">-</strong>
                        </div>
                        <div>
                            <span>Phone</span>
                            <strong id="selectedOutletPhone">-</strong>
                        </div>
                    </div>
                </div>
            </section>

            <section class="pp-card">
                <div class="pp-card-header">
                    <div>
                        <h2>Product Planning</h2>
                        <p>Select product, quantity, color, priority, and destination.</p>
                    </div>
                </div>

                <div class="form-grid two-col">
                    <div class="form-group full">
                        <label asp-for="ProductId">Product</label>
                        <select asp-for="ProductId" id="productDropdown" class="form-control">
                            <option value="">Select Product</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label asp-for="Variant">Color / Variant</label>
                        <select asp-for="Variant" id="variantDropdown" class="form-control">
                            <option value="">Select Color / Variant</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label asp-for="TotalQuantity">Total Quantity</label>
                        <input asp-for="TotalQuantity" type="number" min="1" id="totalQuantity" class="form-control" placeholder="Example: 300" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Priority">Priority</label>
                        <select asp-for="Priority" class="form-control">
                            <option value="Normal">Normal</option>
                            <option value="Urgent">Urgent</option>
                            <option value="Seasonal">Seasonal</option>
                        </select>
                    </div>

                    <div class="form-group full">
                        <label asp-for="OutputDestination">Output Destination</label>
                        <select asp-for="OutputDestination" class="form-control">
                            <option value="Outlet Transfer">Outlet Transfer</option>
                            <option value="Finished Goods Warehouse">Finished Goods Warehouse</option>
                        </select>
                    </div>
                </div>
            </section>

        </div>

        @await Html.PartialAsync("_PlanCommonSections")

    </form>
</div>

<div class="pp-modal hidden" id="outletModal">
    <div class="pp-modal-backdrop" data-close-modal="outletModal"></div>

    <div class="pp-modal-panel large">
        <div class="pp-modal-header">
            <div>
                <h2>Select Outlet</h2>
                <p>Choose outlet from mock outlet master data.</p>
            </div>

            <button type="button" class="modal-close-btn" data-close-modal="outletModal">×</button>
        </div>

        <div class="pp-modal-body">
            <div class="form-group">
                <label for="outletSearch">Search Outlet</label>
                <input type="text" id="outletSearch" class="form-control" placeholder="Search by code, name, location, manager..." />
            </div>

            <div class="pp-table-wrapper mt-20">
                <table class="pp-table">
                    <thead>
                        <tr>
                            <th>Outlet Code</th>
                            <th>Outlet Name</th>
                            <th>Location</th>
                            <th>Manager</th>
                            <th>Phone</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody id="outletGridBody">
                        <tr>
                            <td colspan="6" class="empty-cell">Loading outlets...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="~/js/app.js" asp-append-version="true"></script>

<script src="~/data/outlets.js" asp-append-version="true"></script>
<script src="~/data/products.js" asp-append-version="true"></script>
<script src="~/data/materials.js" asp-append-version="true"></script>
<script src="~/data/bom.js" asp-append-version="true"></script>
<script src="~/data/production-stages.js" asp-append-version="true"></script>

<script src="~/js/production-plan-create.js" asp-append-version="true"></script>