@page
@model Kaam.Pages.Production.CreateCustomerModel
@{
  ViewData["Title"] = "Create Customer Production Plan";
}

<link rel="stylesheet" href="~/css/plan.css" asp-append-version="true" />

<div class="pp-page customer-order-page" id="customerOrderPlanPage" data-selected-customer-id="@Model.CustomerId">

  <div class="pp-page-header">
    <div>
      <h1>Create Customer Order Plan</h1>
      <p id="customerOrderHeaderText">Browse ready customer orders, check materials in bulk, and add selected items to a production plan.</p>
    </div>

    <div class="pp-header-actions">
      <a asp-page="/Production/Customers" class="btn btn-light">
        Choose Customer
      </a>

      <a asp-page="/Production/Create" class="btn btn-light">
        Change Demand Type
      </a>

      <a asp-page="/Production/PlansDetails" class="btn btn-light">
        Back to Plans
      </a>
    </div>
  </div>

  @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
  {
    <div class="alert alert-success">@Model.SuccessMessage</div>
  }

  @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
  {
    <div class="alert alert-danger">@Model.ErrorMessage</div>
  }

  <section class="pp-card selected-customer-card hidden" id="selectedCustomerCard">
    <div class="selected-customer-main">
      <div class="selected-customer-avatar" id="selectedCustomerAvatar">CU</div>
      <div>
        <span class="catalog-eyebrow">Selected Customer</span>
        <h2 id="selectedCustomerName">Customer</h2>
        <p id="selectedCustomerMeta">Order items for the selected customer.</p>
      </div>
    </div>

    <div class="selected-customer-stats">
      <div>
        <span>Phone</span>
        <strong id="selectedCustomerPhone">-</strong>
      </div>
      <div>
        <span>Location</span>
        <strong id="selectedCustomerAddress">-</strong>
      </div>
      <div>
        <span>Open Orders</span>
        <strong id="selectedCustomerOrders">0</strong>
      </div>
      <div>
        <span>Total Qty</span>
        <strong id="selectedCustomerQty">0</strong>
      </div>
      <div>
        <span>Earliest Delivery</span>
        <strong id="selectedCustomerDelivery">-</strong>
      </div>
    </div>
  </section>

  <div class="alert alert-warning hidden" id="customerSelectionWarning">
    Choose a customer from the customer catalog to view only that customer's order items.
  </div>

  <form method="post" id="productionPlanForm">

    <input asp-for="DemandType" type="hidden" value="Customer Order" />
    <input asp-for="SelectedDraftJson" type="hidden" id="selectedDraftJson" />

    <section class="pp-card catalog-hero-card">
      <div class="catalog-hero-content">
        <div>
          <span class="catalog-eyebrow">Customer Order Catalog</span>
          <h2 id="customerOrderCatalogTitle">Ready Orders for Production Planning</h2>
          <!--    <p>
                        Select customer order items like an internal e-commerce catalog.
                        View product image, size breakdown, delivery date, and material status before adding to plan.
                    </p> -->
        </div>

        <div class="catalog-hero-stats">
          <div>
            <span>Selected Items</span>
            <strong id="selectedItemCount">0</strong>
          </div>
          <div>
            <span>Total Quantity</span>
            <strong id="selectedTotalQty">0</strong>
          </div>
          <div>
            <span>Earliest Delivery</span>
            <strong id="selectedEarliestDelivery">-</strong>
          </div>
        </div>
      </div>
    </section>

    <div class="catalog-layout">

      <main class="catalog-main">
        <div class="catalog-section-header">
          <div>
            <h2 id="customerOrderItemsTitle">Customer Order Items</h2>
            <p id="customerOrderItemsText">Click View Details to inspect size chart, measurements, and material requirements.</p>
          </div>
        </div>

        <div id="customerOrderCatalogGrid" class="customer-order-catalog-grid">
          <div class="empty-cell">
            Loading customer orders...
          </div>
        </div>
      </main>

      <aside class="plan-basket-panel">
        <div class="plan-basket-header">
          <div>
            <h2>Production Plan Basket</h2>
            <p>Selected items to convert into production plan.</p>
          </div>
        </div>

        <div id="planBasketItems" class="plan-basket-items">
          <div class="basket-empty-state">
            No items added yet.
          </div>
        </div>

        <div class="plan-basket-summary">
          <div>
            <span>Total Items</span>
            <strong id="basketTotalItems">0</strong>
          </div>
          <div>
            <span>Total Qty</span>
            <strong id="basketTotalQty">0</strong>
          </div>
          <div>
            <span>Earliest Delivery</span>
            <strong id="basketEarliestDelivery">-</strong>
          </div>
          <div>
            <span>Material Status</span>
            <strong id="basketMaterialStatus">Not checked</strong>
          </div>
        </div>

        <div class="basket-actions">
          <button type="button" class="btn btn-outline full-width" id="checkBulkMaterialBtn">
            Check Materials in Bulk
          </button>

          <button type="submit" name="ActionType" value="Create" class="btn btn-primary full-width" id="createProductionPlanBtn">
            Create Production Plan
          </button>

          <button type="button" class="btn btn-danger-light full-width" id="clearBasketBtn">
            Clear Basket
          </button>
        </div>
      </aside>

    </div>

    <section class="pp-card bulk-material-card">
      <div class="pp-card-header">
        <div>
          <h2>Bulk Material Requirement</h2>
          <p>Material requirement is calculated from all selected production plan items.</p>
        </div>
      </div>

      <div class="pp-table-wrapper">
        <table class="pp-table">
          <thead>
            <tr>
              <th>Material Code</th>
              <th>Material Name</th>
              <th>Material Type</th>
              <th>Required Qty</th>
              <th>Available Qty</th>
              <th>Shortage Qty</th>
              <th>Unit</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="bulkMaterialBody">
            <tr>
              <td colspan="8" class="empty-cell">
                Add items to production plan basket, then click Check Materials in Bulk.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

  </form>
</div>

<div class="pp-modal hidden" id="orderDetailModal">
  <div class="pp-modal-backdrop" data-close-modal="orderDetailModal"></div>

  <div class="pp-modal-panel large order-detail-modal-panel">
    <div class="pp-modal-header">
      <div>
        <h2 id="detailProductName">Order Detail</h2>
        <p id="detailOrderSubtitle">View customer order, size chart, measurements, and production information.</p>
      </div>

      <button type="button" class="modal-close-btn" data-close-modal="orderDetailModal">&times;</button>
    </div>

    <div class="pp-modal-body">
      <div class="order-detail-layout">

        <div class="order-detail-media">
          <img id="detailProductImage" src="/images/products/place-holder.png" alt="Product image" />

          <div class="order-detail-thumbnail-row">
            <div>
              <span>Customer</span>
              <strong id="detailCustomerName">-</strong>
            </div>
            <div>
              <span>Order No</span>
              <strong id="detailOrderNo">-</strong>
            </div>
          </div>
        </div>

        <div class="order-detail-info">
          <div class="detail-badge-row">
            <span id="detailCustomerType" class="customer-type">-</span>
            <span id="detailPriority" class="priority-badge">-</span>
            <span id="detailDeliveryBadge" class="customer-delivery-normal">-</span>
          </div>

          <h3 id="detailItemName">-</h3>

          <div class="detail-info-grid">
            <div>
              <span>Quantity</span>
              <strong id="detailQuantity">-</strong>
            </div>
            <div>
              <span>Delivery Date</span>
              <strong id="detailDeliveryDate">-</strong>
            </div>
            <div>
              <span>Color / Variant</span>
              <strong id="detailVariant">-</strong>
            </div>
            <div>
              <span>Delivery Location</span>
              <strong id="detailDeliveryLocation">-</strong>
            </div>
          </div>

          <div class="detail-note-box">
            <span>Production Notes</span>
            <p id="detailProductionNotes">-</p>
          </div>

          <div class="detail-action-stack">
            <button type="button" class="btn btn-outline full-width product-3d-preview-btn" id="openProduct3dPreviewBtn">
              <span class="material-symbols-outlined">view_in_ar</span>
              3D Product Preview
            </button>

            <button type="button" class="btn btn-primary full-width" id="addDetailToPlanBtn">
              Add to Production Plan
            </button>
          </div>
        </div>

      </div>

      <div class="order-detail-tabs">
        <section class="detail-section">
          <div class="detail-section-header">
            <h3>Size Breakdown</h3>
            <p>Quantity required per size and color variant.</p>
          </div>

          <div class="pp-table-wrapper size-breakdown-wrapper">
            <table class="pp-table compact-table size-breakdown-table">
              <colgroup>
                <col class="size-col" />
                <col class="color-col" />
                <col class="qty-col" />
              </colgroup>
              <thead>
                <tr>
                  <th>Size</th>
                  <th>Color</th>
                  <th>Quantity</th>
                </tr>
              </thead>
              <tbody id="detailSizeBreakdownBody">
                <tr>
                  <td colspan="3" class="empty-cell">No size data.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="detail-section">
          <div class="detail-section-header">
            <h3>Measurement Chart</h3>
            <p>Specification used by production team.</p>
          </div>

          <div class="pp-table-wrapper">
            <table class="pp-table compact-table" style="min-width: 245px ; width: stretch; max-width: 900px;">
              <thead>
                <tr>
                  <th style="width: 16.6666667%; white-space: nowrap;">Size</th>
                  <th style="width: 16.6666667%; white-space: nowrap;">Chest</th>
                  <th style="width: 16.6666667%; white-space: nowrap;">Shoulder</th>
                  <th style="width: 16.6666667%; white-space: nowrap;">Sleeve</th>
                  <th style="width: 16.6666667%; white-space: nowrap;">Length</th>
                  <th style="width: 16.6666667%; white-space: nowrap;">Unit</th>
                </tr>
              </thead>
              <tbody id="detailMeasurementBody">
                <tr>
                  <td colspan="6" class="empty-cell">No measurement data.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="detail-section full-detail-section">
          <div class="detail-section-header">
            <h3>Material Requirement Preview</h3>
            <p>Calculated only for this order item.</p>
          </div>

          <div class="pp-table-wrapper">
            <table class="pp-table compact-table">
              <thead>
                <tr>
                  <th>Material</th>
                  <th>Required</th>
                  <th>Available</th>
                  <th>Shortage</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="detailMaterialBody">
                <tr>
                  <td colspan="5" class="empty-cell">No material data.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

    </div>
  </div>
</div>

<div class="pp-modal product-3d-modal hidden" id="product3dPreviewModal">
  <div class="pp-modal-backdrop" data-close-modal="product3dPreviewModal"></div>

  <div class="pp-modal-panel large product-3d-modal-panel">
    <div class="pp-modal-header">
      <div>
        <h2 id="product3dPreviewTitle">3D Product Preview</h2>
        <p id="product3dPreviewSubtitle">Product preview for the selected customer order item.</p>
      </div>

      <div class="product-3d-header-actions">
        <button type="button" class="btn btn-light btn-sm" id="saveProduct3dImageBtn">
          <span class="material-symbols-outlined">download</span>
          Save Image
        </button>

        <button type="button" class="modal-close-btn" data-close-modal="product3dPreviewModal">&times;</button>
      </div>
    </div>

    <div class="pp-modal-body product-3d-modal-body">
      <div class="product-3d-scene" id="product3dScene" aria-label="3D product preview">
        <canvas id="product3dCanvas"></canvas>

        <div class="product-3d-loading" id="product3dLoading">
          Loading 3D preview...
        </div>

        <div class="product-3d-fallback hidden" id="product3dFallback">
          <div class="product-3d-css-model" id="product3dCssModel">
            <div class="product-3d-css-side left"></div>
            <div class="product-3d-css-side right"></div>
            <img id="product3dFallbackImage" src="/images/products/place-holder.png" alt="3D product fallback preview" />
          </div>
        </div>
      </div>

      <div class="product-3d-meta-grid">
        <div>
          <span>Order No</span>
          <strong id="product3dOrderNo">-</strong>
        </div>
        <div>
          <span>Customer</span>
          <strong id="product3dCustomerName">-</strong>
        </div>
        <div>
          <span>Quantity</span>
          <strong id="product3dQuantity">-</strong>
        </div>
        <div>
          <span>Variant</span>
          <strong id="product3dVariant">-</strong>
        </div>
      </div>

      <div class="product-3d-variant-row" id="product3dVariantChips"></div>
    </div>
  </div>
</div>

<script src="~/js/app.js" asp-append-version="true"></script>

<script src="~/data/customers.js" asp-append-version="true"></script>
<script src="~/data/products.js" asp-append-version="true"></script>
<script src="~/data/materials.js" asp-append-version="true"></script>
<script src="~/data/bom.js" asp-append-version="true"></script>
<script src="~/data/production-stages.js" asp-append-version="true"></script>

<script src="~/js/production-plan-create.js" asp-append-version="true"></script>
