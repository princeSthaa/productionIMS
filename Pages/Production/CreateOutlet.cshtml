@page
@model Kaam.Pages.Production.CreateOutletModel
@{
    ViewData["Title"] = "Create Outlet Production Plan";
}

<link rel="stylesheet" href="~/css/plan.css" asp-append-version="true" />

<div class="pp-page outlet-demand-page">

    <div class="pp-page-header">
        <div>
            <h1>Create Outlet Production Plan</h1>
            <p>Browse outlet stock demand, add replenishment items to plan, and check materials in bulk.</p>
        </div>

        <div class="pp-header-actions">
            <a asp-page="/Production/Create" class="btn btn-light">Change Demand Type</a>
            <a asp-page="/Production/Index" class="btn btn-light">Back to Plans</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post" id="outletProductionPlanForm">

        <input asp-for="DemandType" type="hidden" value="Outlet Demand" />
        <input asp-for="SelectedDraftJson" type="hidden" id="selectedOutletDraftJson" />

        <section class="pp-card catalog-hero-card">
            <div class="catalog-hero-content">
                <div>
                    <span class="catalog-eyebrow">Outlet Demand Catalog</span>
                    <h2>Outlet Replenishment Planning</h2>
                    <p>
                        Select products that need production for outlet stock replenishment.
                        Review stock gap, sales velocity, suggested quantity, and material availability.
                    </p>
                </div>

                <div class="catalog-hero-stats">
                    <div>
                        <span>Selected Items</span>
                        <strong id="outletSelectedItemCount">0</strong>
                    </div>
                    <div>
                        <span>Total Suggested Qty</span>
                        <strong id="outletSelectedTotalQty">0</strong>
                    </div>
                    <div>
                        <span>Earliest Required</span>
                        <strong id="outletSelectedEarliestDate">-</strong>
                    </div>
                </div>
            </div>
        </section>

        <section class="pp-card catalog-filter-card">
            <div class="catalog-filter-grid outlet-filter-grid">
                <div class="form-group">
                    <label for="outletSearch">Search Demand</label>
                    <input type="text"
                           id="outletSearch"
                           class="form-control"
                           placeholder="Search outlet, product, category, location..." />
                </div>

                <div class="form-group">
                    <label for="outletFilter">Outlet</label>
                    <select id="outletFilter" class="form-control">
                        <option value="">All Outlets</option>
                        <option value="New Road Outlet">New Road Outlet</option>
                        <option value="Lalitpur Outlet">Lalitpur Outlet</option>
                        <option value="Pokhara Outlet">Pokhara Outlet</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="stockStatusFilter">Stock Status</label>
                    <select id="stockStatusFilter" class="form-control">
                        <option value="">All Status</option>
                        <option value="Critical">Critical</option>
                        <option value="Low Stock">Low Stock</option>
                        <option value="Reorder Soon">Reorder Soon</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="velocityFilter">Sales Velocity</label>
                    <select id="velocityFilter" class="form-control">
                        <option value="">All Velocity</option>
                        <option value="Fast">Fast</option>
                        <option value="Normal">Normal</option>
                        <option value="Slow">Slow</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="outletSort">Sort By</label>
                    <select id="outletSort" class="form-control">
                        <option value="requiredDate">Nearest Required Date</option>
                        <option value="stockGapHigh">Stock Gap High to Low</option>
                        <option value="salesVelocity">Sales Velocity</option>
                        <option value="outletName">Outlet Name</option>
                    </select>
                </div>
            </div>
        </section>

        <div class="catalog-layout">

            <main class="catalog-main">
                <div class="catalog-section-header">
                    <div>
                        <h2>Outlet Demand Items</h2>
                        <p>Choose products that need production based on outlet stock gap and sales movement.</p>
                    </div>
                </div>

                <div id="outletDemandCatalogGrid" class="customer-order-catalog-grid outlet-demand-catalog-grid">
                    <div class="empty-cell">
                        Loading outlet demand...
                    </div>
                </div>
            </main>

            <aside class="plan-basket-panel">
                <div class="plan-basket-header">
                    <h2>Plan Basket</h2>
                    <p>Review selected outlet demand items before creating the production plan.</p>
                </div>

                <div id="outletPlanBasketItems" class="plan-basket-items">
                    <div class="basket-empty-state">
                        No outlet demand items added yet.
                    </div>
                </div>

                <div class="plan-basket-summary">
                    <div>
                        <span>Total Items</span>
                        <strong id="outletBasketTotalItems">0</strong>
                    </div>
                    <div>
                        <span>Total Qty</span>
                        <strong id="outletBasketTotalQty">0</strong>
                    </div>
                    <div>
                        <span>Earliest Required</span>
                        <strong id="outletBasketEarliestDate">-</strong>
                    </div>
                    <div>
                        <span>Material Status</span>
                        <strong id="outletBasketMaterialStatus">Not checked</strong>
                    </div>
                </div>

                <div class="basket-actions">
                    <button type="submit" name="ActionType" value="Create" class="btn btn-primary full-width">
                        Create Production Plan
                    </button>

                    <button type="button" class="btn btn-outline full-width" id="checkOutletBulkMaterialBtn">
                        Check Materials in Bulk
                    </button>

                    <button type="button" class="btn btn-danger-light full-width" id="clearOutletBasketBtn">
                        Clear Basket
                    </button>
                </div>
            </aside>

        </div>

        <section class="pp-card bulk-material-card">
            <div class="pp-card-header">
                <div>
                    <h2>Bulk Material Requirement</h2>
                    <p>Material requirement is calculated from all selected outlet demand items.</p>
                </div>
            </div>

            <div class="pp-table-wrapper">
                <table class="pp-table">
                    <thead>
                        <tr>
                            <th>Material Code</th>
                            <th>Material Name</th>
                            <th>Material Type</th>
                            <th>Required Qty</th>
                            <th>Available Qty</th>
                            <th>Shortage Qty</th>
                            <th>Unit</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="outletBulkMaterialBody">
                        <tr>
                            <td colspan="8" class="empty-cell">
                                Add outlet demand items to plan basket, then click Check Materials in Bulk.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

    </form>
</div>

<div class="pp-modal hidden" id="outletDetailModal">
    <div class="pp-modal-backdrop" data-close-modal="outletDetailModal"></div>

    <div class="pp-modal-panel large order-detail-modal-panel">
        <div class="pp-modal-header">
            <div>
                <h2 id="outletDetailProductName">Outlet Demand Detail</h2>
                <p id="outletDetailSubtitle">Review outlet stock gap, size-wise demand, and material requirement.</p>
            </div>

            <button type="button" class="modal-close-btn" data-close-modal="outletDetailModal">×</button>
        </div>

        <div class="pp-modal-body">
            <div class="order-detail-layout">

                <div class="order-detail-media">
                    <img id="outletDetailProductImage"
                         src="/images/placeholder-product.png"
                         alt="Product image" />

                    <div class="order-detail-thumbnail-row">
                        <div>
                            <span>Outlet</span>
                            <strong id="outletDetailOutletName">-</strong>
                        </div>
                        <div>
                            <span>Demand No</span>
                            <strong id="outletDetailDemandNo">-</strong>
                        </div>
                    </div>
                </div>

                <div class="order-detail-info">
                    <div class="detail-badge-row">
                        <span id="outletDetailStockStatus" class="priority-badge">-</span>
                        <span id="outletDetailVelocity" class="customer-delivery-normal">-</span>
                        <span id="outletDetailRequiredBadge" class="customer-delivery-normal">-</span>
                    </div>

                    <h3 id="outletDetailItemName">-</h3>

                    <div class="detail-info-grid">
                        <div>
                            <span>Current Stock</span>
                            <strong id="outletDetailCurrentStock">-</strong>
                        </div>
                        <div>
                            <span>Reorder Level</span>
                            <strong id="outletDetailReorderLevel">-</strong>
                        </div>
                        <div>
                            <span>Suggested Qty</span>
                            <strong id="outletDetailSuggestedQty">-</strong>
                        </div>
                        <div>
                            <span>Required Date</span>
                            <strong id="outletDetailRequiredDate">-</strong>
                        </div>
                        <div>
                            <span>Last 30 Days Sales</span>
                            <strong id="outletDetailLast30Sales">-</strong>
                        </div>
                        <div>
                            <span>Outlet Location</span>
                            <strong id="outletDetailLocation">-</strong>
                        </div>
                    </div>

                    <div class="detail-note-box">
                        <span>Planning Notes</span>
                        <p id="outletDetailNotes">-</p>
                    </div>

                    <button type="button" class="btn btn-primary full-width" id="addOutletDetailToPlanBtn">
                        Add to Production Plan
                    </button>
                </div>

            </div>

            <div class="order-detail-tabs">
                <section class="detail-section">
                    <div class="detail-section-header">
                        <h3>Size-wise Stock Gap</h3>
                        <p>Suggested quantity per size.</p>
                    </div>

                    <div class="pp-table-wrapper">
                        <table class="pp-table compact-table">
                            <thead>
                                <tr>
                                    <th>Size</th>
                                    <th>Current</th>
                                    <th>Reorder</th>
                                    <th>Suggested</th>
                                </tr>
                            </thead>
                            <tbody id="outletDetailSizeGapBody">
                                <tr>
                                    <td colspan="4" class="empty-cell">No size gap data.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="detail-section">
                    <div class="detail-section-header">
                        <h3>Sales Summary</h3>
                        <p>Outlet sales movement.</p>
                    </div>

                    <div class="outlet-sales-summary-grid">
                        <div>
                            <span>Last 7 Days</span>
                            <strong id="outletDetailLast7Sales">-</strong>
                        </div>
                        <div>
                            <span>Last 30 Days</span>
                            <strong id="outletDetailSales30Box">-</strong>
                        </div>
                        <div>
                            <span>Average Daily Sales</span>
                            <strong id="outletDetailAvgDailySales">-</strong>
                        </div>
                    </div>
                </section>

                <section class="detail-section full-detail-section">
                    <div class="detail-section-header">
                        <h3>Material Requirement Preview</h3>
                        <p>Calculated only for this outlet demand item.</p>
                    </div>

                    <div class="pp-table-wrapper">
                        <table class="pp-table compact-table">
                            <thead>
                                <tr>
                                    <th>Material</th>
                                    <th>Required</th>
                                    <th>Available</th>
                                    <th>Shortage</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="outletDetailMaterialBody">
                                <tr>
                                    <td colspan="5" class="empty-cell">No material data.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>

        </div>
    </div>
</div>

<script src="~/js/app.js" asp-append-version="true"></script>

<script src="~/data/outlet-demands.js" asp-append-version="true"></script>
<script src="~/data/products.js" asp-append-version="true"></script>
<script src="~/data/materials.js" asp-append-version="true"></script>
<script src="~/data/bom.js" asp-append-version="true"></script>

