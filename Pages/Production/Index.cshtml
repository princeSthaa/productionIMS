@page
@model Kaam.Pages.Production.IndexModel
@{
  ViewData["Title"] = "Production Plans";

  Layout = "_SidebarLayout";
}


<div class="pp-page">

  <!-- Page Header -->
  <div class="pp-page-header">
    <div>
      <h1>Production Plans</h1>
      <p>View, filter, and manage garment production plans.</p>
    </div>

    <div class="pp-header-actions">
      <a asp-page="/Production/Create" class="btn btn-primary">
        + Create Production Plan
      </a>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="pp-summary-grid">
    <div class="pp-summary-card">
      <span class="summary-label">Total Plans</span>
      <strong id="totalPlans">0</strong>
      <small>All production plans</small>
    </div>

    <div class="pp-summary-card">
      <span class="summary-label">Draft</span>
      <strong id="draftPlans">0</strong>
      <small>Plans not yet confirmed</small>
    </div>

    <div class="pp-summary-card">
      <span class="summary-label">In Progress</span>
      <strong id="inProgressPlans">0</strong>
      <small>Currently running</small>
    </div>

    <div class="pp-summary-card">
      <span class="summary-label">Completed</span>
      <strong id="completedPlans">0</strong>
      <small>Finished plans</small>
    </div>
  </div>
</div>
<script src="~/js/app.js" asp-append-version="true"></script>
<script src="~/data/mock-production-plans.js" asp-append-version="true"></script>
<script src="~/js/production-plan-index.js" asp-append-version="true"></script>
