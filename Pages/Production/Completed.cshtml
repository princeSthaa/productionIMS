@page
@model Kaam.Pages.Production.CompletedModel
@{
  ViewData["Title"] = "Completed Production";
}

<link rel="stylesheet" href="~/css/production/production-plans.css" asp-append-version="true" />

<div class="pp-page production-folder-page" data-production-folder="completed">
  <div class="pp-page-header">
    <div>
      <h1>Completed Production</h1>
      <p>Finished plans ready for the next business step.</p>
    </div>

    <div class="pp-header-actions">
      <a asp-page="/Production/Plan/PlansDetails" class="btn btn-light">View All Plans</a>
      <a asp-page="/Production/Index" class="btn btn-light">Overview</a>
    </div>
  </div>

  <section class="pp-card production-folder-card">
    <div class="folder-page-toolbar">
      <div class="folder-search">
        <span class="material-symbols-outlined">search</span>
        <input type="search" id="folderSearchInput" placeholder="Search completed" aria-label="Search completed" />
      </div>
    </div>

    <div class="folder-summary-strip">
      <div>
        <span>Completed Plans</span>
        <strong id="folderPlanCount">0</strong>
      </div>
      <div>
        <span>Total Qty</span>
        <strong id="folderTotalQty">0</strong>
      </div>
      <div>
        <span>Demand Sources</span>
        <strong id="folderDemandCount">0</strong>
      </div>
    </div>

    <div class="folder-list-header no-selection">
      <div class="header-icon"></div>
      <div class="header-info">Plan Details</div>
      <div class="header-date">Last Edited</div>
      <div class="header-actions">Actions</div>
    </div>

    <div id="folderPlanList" class="folder-plan-list">
      <div class="empty-cell">Loading completed plans...</div>
    </div>
  </section>
</div>

<script src="~/js/app.js" asp-append-version="true"></script>
<script src="~/data/production/mock-production-plans.js" asp-append-version="true"></script>
<script src="~/js/production/production-draft-store.js" asp-append-version="true"></script>
<script src="~/js/production/production-plan-folder.js" asp-append-version="true"></script>
