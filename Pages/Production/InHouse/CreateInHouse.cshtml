@page
@model Kaam.Pages.Production.CreateInHouseModel
@{
    ViewData["Title"] = "Create In-house Production Plan";
}

<link rel="stylesheet" href="~/css/production/plan.css" asp-append-version="true" />
<link rel="stylesheet" href="https://nepalidatepicker.sajanmaharjan.com.np/v5/nepali.datepicker/css/nepali.datepicker.v5.0.6.min.css" />

<div class="pp-page inhouse-plan-page" id="inHousePlanPage">

    <div class="pp-page-header">
        <div>
            <h1>Create In-house Stock Plan</h1>
            <p>Plan garment production for internal warehouse stock.</p>
        </div>

        <div class="pp-header-actions">
            <a asp-page="/Production/Create" class="btn btn-light">Change Demand Type</a>
            <a asp-page="/Production/Plan/PlansDetails" class="btn btn-light">Back to Plans</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post" id="productionPlanForm">

        <input asp-for="DemandType" type="hidden" id="demandType" value="In-house Stock" />
        <input asp-for="Variant" type="hidden" id="variantSummaryInput" />
        <input asp-for="VariantBreakdownJson" type="hidden" id="variantBreakdownJson" />

        <div class="pp-create-grid">

            <section class="pp-card">
                <div class="pp-card-header">
                    <div>
                        <h2>In-house Stock Information</h2>
                        <p>Select reason and warehouse for internal production.</p>
                    </div>
                </div>

                <div class="form-grid two-col">
                    <div class="form-group">
                        <label asp-for="PlanNo">Plan No</label>
                        <input asp-for="PlanNo" class="form-control" readonly />
                    </div>

                    <div class="form-group">
                        <label for="planDateBs">Plan Date (BS)</label>
                        <input type="text" id="planDateBs" class="form-control nepali-date inhouse-bs-date" placeholder="YYYY-MM-DD" readonly />
                        <input asp-for="PlanDate" type="date" id="planDate" class="form-control hidden-ad-date" readonly />
                    </div>
                </div>

                <div id="inHouseSection" class="conditional-section">
                    <h3>In-house Stock</h3>
                    <p>Create a production plan for internal stock requirement.</p>

                    <div class="form-grid two-col">
                        <div class="form-group">
                            <label asp-for="InHouseReason">Reason</label>
                            <select asp-for="InHouseReason" id="inHouseReason" class="form-control">
                                <option value="">Select Reason</option>
                                <option value="Stock Replenishment">Stock Replenishment</option>
                                <option value="Seasonal Production">Seasonal Production</option>
                                <option value="Forecast Demand">Forecast Demand</option>
                                <option value="Sample Production">Sample Production</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label asp-for="WarehouseId">Warehouse</label>
                            <select asp-for="WarehouseId" id="warehouseDropdown" class="form-control">
                                <option value="">Select Warehouse</option>
                            </select>
                        </div>
                    </div>
                </div>
            </section>

            <section class="pp-card">
                <div class="pp-card-header">
                    <div>
                        <h2>Product Planning Production Stages</h2>
                        <p>Select product, quantity, color, priority, and destination.</p>
                    </div>
                </div>

                <div class="form-grid two-col">
                    <div class="form-group full">
                        <label asp-for="ProductId">Product</label>
                        <select asp-for="ProductId" id="productDropdown" class="form-control">
                            <option value="">Select Product</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="variantDropdown">Color / Variant</label>
                        <select id="variantDropdown" class="form-control">
                            <option value="">Select Color / Variant</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label asp-for="TotalQuantity">Total Quantity</label>
                        <input asp-for="TotalQuantity" type="number" min="1" id="totalQuantity" class="form-control" placeholder="Example: 220" readonly />
                    </div>

                    <div class="form-group">
                        <label asp-for="Priority">Priority</label>
                        <select asp-for="Priority" class="form-control">
                            <option value="Normal">Normal</option>
                            <option value="Urgent">Urgent</option>
                            <option value="Seasonal">Seasonal</option>
                        </select>
                    </div>

                    <div class="form-group full">
                        <label asp-for="OutputDestination">Output Destination</label>
                        <select asp-for="OutputDestination" class="form-control">
                            <option value="Finished Goods Warehouse">Finished Goods Warehouse</option>
                        </select>
                    </div>
                </div>
            </section>

        </div>

        <section class="pp-card variant-quantity-card">
            <div class="pp-card-header">
                <div>
                    <h2>Color Variant Quantities</h2>
                    <p>Plan quantity by color variant for the selected in-house product.</p>
                </div>
            </div>

            <div class="variant-entry-grid">
                <div class="form-group">
                    <label for="inhouseVariantQty">Variant Quantity</label>
                    <input type="number" min="1" id="inhouseVariantQty" class="form-control" placeholder="Example: 120" />
                </div>

                <button type="button" class="btn btn-primary" id="addInhouseVariantBtn">
                    Add Variant Quantity
                </button>
            </div>

            <div id="inhouseVariantRows" class="variant-breakdown-list">
                <div class="basket-empty-state">No color variant quantity added.</div>
            </div>
        </section>

        <section class="pp-card measurement-chart-card">
            <div class="pp-card-header">
                <div>
                    <h2>Measurement Chart</h2>
                    <p>Specification used by production team.</p>
                </div>
            </div>

            <div class="pp-table-wrapper">
                <table class="pp-table compact-table">
                    <thead>
                        <tr>
                            <th>Size</th>
                            <th>Chest</th>
                            <th>Shoulder</th>
                            <th>Sleeve</th>
                            <th>Length</th>
                            <th>Unit</th>
                        </tr>
                    </thead>
                    <tbody id="inhouseMeasurementBody">
                        <tr>
                            <td colspan="6" class="empty-cell">Select product to view measurement data.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        @await Html.PartialAsync("/Pages/Production/Plan/_PlanCommonSections.cshtml")

    </form>
</div>

<script src="~/js/app.js" asp-append-version="true"></script>

<script src="~/data/warehouse/warehouses.js" asp-append-version="true"></script>
<script src="~/data/shared/products.js" asp-append-version="true"></script>
<script src="~/data/shared/materials.js" asp-append-version="true"></script>
<script src="~/data/shared/bom.js" asp-append-version="true"></script>
<script src="~/data/production/production-stages.js" asp-append-version="true"></script>

<script src="https://nepalidatepicker.sajanmaharjan.com.np/v5/nepali.datepicker/js/nepali.datepicker.v5.0.6.min.js"
        type="text/javascript"></script>
<script src="~/js/production/inhouse-plan-create.js" asp-append-version="true"></script>
