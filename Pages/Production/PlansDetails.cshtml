@page "{id?}"
@model Kaam.Pages.Production.PlansDetailsModel
@{
    ViewData["Title"] = "Production Plans";
    Layout = "_SidebarLayout";
}

<link rel="stylesheet" href="~/css/production-plans-details.css" asp-append-version="true" />

<div class="plans-page">

    <div class="plans-page-header">
        <div>
            <h1>Production Plans</h1>
            <p>
                Select a plan from the list and use the quick reference before opening the full details or edit screen.
            </p>
        </div>

        <div class="plans-header-actions">
            <a asp-page="/Production/Create" class="btn btn-primary">
                + Create Production Plan
            </a>
        </div>
    </div>

    <input type="hidden" id="selectedPlanNoFromRoute" value="@Model.PlanNo" />

    <div class="pp-card">
    <div class="pp-card-header">
      <div>
        <h2>Filter Production Plans</h2>
        <p>Search by product, source, demand type, status, or date range.</p>
      </div>

      <button type="button" class="btn btn-light" id="resetFiltersBtn">
        Reset Filters
      </button>
    </div>

    <div class="pp-filter-grid">
      <div class="form-group">
        <label for="demandTypeFilter">Demand Type</label>
        <select id="demandTypeFilter" class="form-control">
          <option value="">All Demand Types</option>
          <option value="Customer Order">Customer Order</option>
          <option value="Outlet Replenishment">Outlet Replenishment</option>
          <option value="In-house Stock">In-house Stock</option>
        </select>
      </div>

      <div class="form-group">
        <label for="statusFilter">Status</label>
        <select id="statusFilter" class="form-control">
          <option value="">All Statuses</option>
          <option value="Draft">Draft</option>
          <option value="Material Check">Material Check</option>
          <option value="Cutting">Cutting</option>
          <option value="Stitching">Stitching</option>
          <option value="Finishing">Finishing</option>
          <option value="Quality Check">Quality Check</option>
          <option value="Packing">Packing</option>
          <option value="Completed">Completed</option>
          <option value="On Hold">On Hold</option>
        </select>
      </div>

      <div class="form-group">
        <label for="fromDateFilter">From Date (BS)</label>
        <input type="text" id="fromDateFilter" class="form-control nepali-date" placeholder="DD-MM-YYYY" readonly />
      </div>

      <div class="form-group">
        <label for="toDateFilter">To Date (BS)</label>
        <input type="text" id="toDateFilter" class="form-control nepali-date " placeholder="DD-MM-YYYY" readonly />
      </div>

      <div class="form-group">
        <label for="productSearch">Product Search</label>
        <input type="text" id="productSearch" class="form-control" placeholder="Search product name..." />
      </div>

      <div class="form-group">
        <label for="sourceSearch">Source Search</label>
        <input type="text" id="sourceSearch" class="form-control" placeholder="Search customer, outlet, warehouse..." />
      </div>
    </div>
    </div>

    <div class="plan-view-toolbar" role="group" aria-label="Production plan view">
        <button type="button" class="view-toggle-btn active" data-plan-view="table">
            Table View
        </button>
        <button type="button" class="view-toggle-btn" data-plan-view="card">
            Card View
        </button>
    </div>

    <section class="plans-table-card" id="planTableView">
        <div class="plans-card-header">
            <div>
                <h2>Plan Table</h2>
                <p>Scan production plans quickly and open the full details when needed.</p>
            </div>
        </div>

        <div class="table-wrap">
            <table class="plan-table">
                <thead>
                    <tr>
                        <th>Plan No</th>
                        <th>Demand Type</th>
                        <th>Source</th>
                        <th>Products</th>
                        <th>Total Qty</th>
                        <th>Required Range</th>
                        <th>Status</th>
                        <th>Risk</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="planTableBody">
                    <tr>
                        <td colspan="9" class="empty-cell">Loading plans...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div id="planTablePagination" class="plan-pagination"></div>
    </section>

    <div class="plans-detail-layout hidden" id="planCardView">

        <section class="plans-list-card">
            <div class="plans-card-header">
                <div>
                    <h2>Plan Cards</h2>
                    <p>One card represents one production plan.</p>
                </div>
            </div>

            <div id="planList" class="plan-list">
                <div class="empty-cell">Loading plans...</div>
            </div>

            <div id="planPagination" class="plan-pagination"></div>
        </section>

        <section class="plan-detail-card">
            <div class="plans-card-header">
                <div>
                    <h2>Plan Detail</h2>
                    <p>Selected plan summary and quick product reference.</p>
                </div>

                <div class="plans-detail-actions">
                    <a id="viewPlanDetailsBtn"
                       asp-page="/Production/Details"
                       asp-route-id="@Model.PlanNo"
                       class="btn btn-light">
                        View Details
                    </a>

                    <a id="editPlanBtn"
                       asp-page="/Production/Edit"
                       asp-route-id="@Model.PlanNo"
                       class="btn btn-primary">
                        Edit
                    </a>
                </div>
            </div>

            <div id="planDetailBody" class="plan-detail-body">
                <div class="empty-cell">Select a plan to view details.</div>
            </div>
        </section>

    </div>

</div>

<script src="~/js/app.js" asp-append-version="true"></script>
<script src="~/data/mock-production-plans.js" asp-append-version="true"></script>
<script src="~/js/production-plans-details.js" asp-append-version="true"></script>
<script src="https://nepalidatepicker.sajanmaharjan.com.np/v5/nepali.datepicker/js/nepali.datepicker.v5.0.6.min.js"
        type="text/javascript"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // 1. Select your input elements
        var fromDateInput = document.getElementById("fromDateFilter");
        var toDateInput = document.getElementById("toDateFilter");

        // 2. Create your configuration object
        var datePickerOptions = {
            miniEnglishDates: true
            // You can add other options here later, comma-separated, like:
            // ndpYear: true,
            // ndpMonth: true
        };

        // 3. Pass the options object into the initialization functions
        if (fromDateInput) {
            fromDateInput.nepaliDatePicker(datePickerOptions);
        }

        if (toDateInput) {
            toDateInput.nepaliDatePicker(datePickerOptions);
        }
    });
</script>
